{
  "name": "virtualization-lib",
  "version": "0.0.9",
  "description": "Лёгкая библиотека для виртуализации простых списков в React.",
  "license": "MIT",
  "author": "skiDIx",
  "keywords": [
    "react",
    "virtualization",
    "virtual-list",
    "virtual-scroll",
    "windowing",
    "performance"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xtansy/virtualization.git"
  },
  "homepage": "https://xtansy.github.io/virtualization/",
  "bugs": {
    "url": "https://github.com/xtansy/virtualization/issues"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "types": "./dist/index.d.ts",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "ladle serve",
    "build": "tsup",
    "build:ladle": "ladle build",
    "preview": "ladle build && ladle preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint --fix"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@ladle/react": "^5.1.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.29.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.2.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.4.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsup": "^8.5.1",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.34.1",
    "vitest": "^4.1.9"
  }
}
